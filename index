</script>
        </div>
    </section>

    <section id="sacrale-geometrie">
        <h2>3. Sacrale Geometrie: Levensbloem (Flower of Life) Expressie</h2>
        <p>Wiskundige berekening van het aantal overlappende sferen/cirkels per radiale progressie $n$. Formule: $3n^2 - 3n + 1$.</p>
        <table>
            <thead>
                <tr>
                    <th>Iteratie / Progressie (n)</th>
                    <th>Toepassing (Geometrisch Patroon)</th>
                    <th>Aantal overlappende eenheden</th>
                </tr>
            </thead>
            <tbody id="geometrie-tabel">
                </tbody>
        </table>
        
        <script>
            function flowerOfLifeFormula(n) {
                return (3 * Math.pow(n, 2)) - (3 * n) + 1;
            }
            
            const tbody = document.getElementById('geometrie-tabel');
            const fasen =;
            
            for(let i = 1; i <= 6; i++) {
                let row = `<tr>
                    <td>${i}</td>
                    <td>${fasen[i-1]}</td>
                    <td>${flowerOfLifeFormula(i)}</td>
                </tr>`;
                tbody.innerHTML += row;
            }
        </script>
    </section>

</body>
