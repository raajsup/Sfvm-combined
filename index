    <section id="vortex-math">
        <h2>2. Vortex Wiskunde (Modulo 9 Sequentie Generator)</h2>
        <p>JavaScript implementatie van de VBM verdubbelingssequentie (1-2-4-8-7-5) via Base-10 digitale reductie.</p>
        <div class="code-block">
<script>
// JavaScript logica voor de digitale wortel en de VBM-verdubbelingssequentie
function digitalRoot(n) {
    if (n === 0) return 0;
    return (n % 9 === 0)? 9 : (n % 9);
}

function genereerVortexSequentie(iteraties) {
    let sequentie =;
    let huidigGetal = 1;
    for (let i = 0; i < iteraties; i++) {
        sequentie.push(digitalRoot(huidigGetal));
        huidigGetal *= 2;
    }
    return sequentie;
}

// Resultaat weergave voor 6 iteraties:
